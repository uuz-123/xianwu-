.page {
  min-height: 100vh;
  background: #fff;
  padding: 0 60rpx;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 60rpx;
}

.logo {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #ff6b35 0%, #ff8c5a 100%);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 70rpx;
  margin-bottom: 24rpx;
}

.app-name {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.app-slogan {
  font-size: 26rpx;
  color: #999;
}

.tabs {
  display: flex;
  margin-bottom: 50rpx;
}

.tab {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  color: #999;
  padding-bottom: 20rpx;
  position: relative;
}

.tab.active {
  color: #333;
  font-weight: bold;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: #ff6b35;
  border-radius: 3rpx;
}

.form-section {
  margin-bottom: 60rpx;
}

.form-item {
  display: flex;
  align-items: center;
  height: 96rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  height: 100%;
}

.form-placeholder {
  color: #ccc;
  font-size: 28rpx;
}

.form-tips {
  display: flex;
  justify-content: flex-end;
  padding: 20rpx 0 30rpx;
}

.forget-pwd {
  font-size: 26rpx;
  color: #ff6b35;
}

.btn-primary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #ff6b35 0%, #ff4e50 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  border: none;
  margin-top: 20rpx;
}

.btn-primary::after {
  border: none;
}

.other-login {
  margin-top: 60rpx;
}

.divider-text {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  font-size: 24rpx;
  color: #999;
}

.divider-line {
  width: 100rpx;
  height: 1rpx;
  background: #eee;
  margin: 0 20rpx;
}

.wechat-login {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background: #f5f5f5;
  border-radius: 44rpx;
  font-size: 28rpx;
  color: #333;
}

.wechat-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.agreement {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 40rpx;
  text-align: center;
  font-size: 22rpx;
  color: #999;
}

.link {
  color: #ff6b35;
}
