<view class="page">
  <view class="logo-section">
    <view class="logo">🥕</view>
    <view class="app-name">鲜物</view>
    <view class="app-slogan">新鲜直达 · 品质保证</view>
  </view>

  <view class="tabs">
    <view class="tab {{currentTab === 'login' ? 'active' : ''}}" bindtap="switchTab" data-tab="login">
      登录
    </view>
    <view class="tab {{currentTab === 'register' ? 'active' : ''}}" bindtap="switchTab" data-tab="register">
      注册
    </view>
  </view>

  <view class="form-section" wx:if="{{currentTab === 'login'}}">
    <view class="form-item">
      <text class="form-icon">📱</text>
      <input 
        class="form-input" 
        type="number"
        placeholder="请输入手机号" 
        placeholder-class="form-placeholder"
        value="{{form.phone}}"
        bindinput="onInput"
        data-field="phone"
        maxlength="11"
      />
    </view>
    <view class="form-item">
      <text class="form-icon">🔒</text>
      <input 
        class="form-input" 
        password="{{true}}"
        placeholder="请输入密码" 
        placeholder-class="form-placeholder"
        value="{{form.password}}"
        bindinput="onInput"
        data-field="password"
        maxlength="20"
      />
    </view>
    <view class="form-tips">
      <text class="forget-pwd" bindtap="forgetPassword">忘记密码？</text>
    </view>
    <button class="btn-primary" bindtap="login">登录</button>
  </view>

  <view class="form-section" wx:if="{{currentTab === 'register'}}">
    <view class="form-item">
      <text class="form-icon">📱</text>
      <input 
        class="form-input" 
        type="number"
        placeholder="请输入手机号" 
        placeholder-class="form-placeholder"
        value="{{form.phone}}"
        bindinput="onInput"
        data-field="phone"
        maxlength="11"
      />
    </view>
    <view class="form-item">
      <text class="form-icon">📝</text>
      <input 
        class="form-input" 
        placeholder="请输入昵称" 
        placeholder-class="form-placeholder"
        value="{{form.nickName}}"
        bindinput="onInput"
        data-field="nickName"
        maxlength="20"
      />
    </view>
    <view class="form-item">
      <text class="form-icon">🔒</text>
      <input 
        class="form-input" 
        password="{{true}}"
        placeholder="请设置密码" 
        placeholder-class="form-placeholder"
        value="{{form.password}}"
        bindinput="onInput"
        data-field="password"
        maxlength="20"
      />
    </view>
    <view class="form-item">
      <text class="form-icon">🔒</text>
      <input 
        class="form-input" 
        password="{{true}}"
        placeholder="请确认密码" 
        placeholder-class="form-placeholder"
        value="{{form.confirmPassword}}"
        bindinput="onInput"
        data-field="confirmPassword"
        maxlength="20"
      />
    </view>
    <button class="btn-primary" bindtap="register">注册</button>
  </view>

  <view class="other-login">
    <view class="divider-text">
      <view class="divider-line"></view>
      <text>其他登录方式</text>
      <view class="divider-line"></view>
    </view>
    <view class="wechat-login" bindtap="wechatLogin">
      <text class="wechat-icon">💚</text>
      <text>微信一键登录</text>
    </view>
  </view>

  <view class="agreement">
    <text>登录即表示同意</text>
    <text class="link">《用户协议》</text>
    <text>和</text>
    <text class="link">《隐私政策》</text>
  </view>
</view>
