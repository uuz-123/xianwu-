<view class="page">
  <scroll-view scroll-y="true" class="content" enhanced="true" show-scrollbar="false">
    <swiper class="product-swiper" indicator-dots="true" autoplay="true" interval="3000" duration="500" circular="true" indicator-color="rgba(0,0,0,0.3)" indicator-active-color="#ff6b35">
      <swiper-item wx:for="{{product.images}}" wx:key="index">
        <image src="{{item}}" class="swiper-image" mode="aspectFill"></image>
      </swiper-item>
    </swiper>

    <view class="product-info card">
      <view class="price-row">
        <view class="current-price">
          <text class="symbol">¥</text>
          <text class="price">{{currentPrice}}</text>
        </view>
        <view class="original-price" wx:if="{{product.originalPrice}}">
          ¥{{product.originalPrice}}
        </view>
        <view class="sales-info">
          <text>已售{{product.sales}}件</text>
        </view>
      </view>
      <view class="product-name">{{product.name}}</view>
      <view class="product-tags">
        <text class="tag tag-hot" wx:if="{{product.isHot}}">热卖</text>
        <text class="tag tag-new" wx:if="{{product.isNew}}">新品</text>
        <text class="tag tag-sale" wx:if="{{product.originalPrice > product.price}}">特惠</text>
      </view>
      <view class="delivery-info">
        <text class="label">配送</text>
        <text class="value">顺丰冷链 · 次日达 · 支持7天无理由</text>
      </view>
    </view>

    <view class="spec-section card" bindtap="showSpecPopup">
      <view class="spec-row">
        <text class="spec-label">规格</text>
        <text class="spec-value">{{selectedSpec ? selectedSpec.name : '请选择规格'}}</text>
        <text class="arrow">›</text>
      </view>
      <view class="spec-row">
        <text class="spec-label">数量</text>
        <view class="quantity-selector">
          <view class="qty-btn minus" bindtap="decreaseQty">-</view>
          <text class="qty-value">{{quantity}}</text>
          <view class="qty-btn plus" bindtap="increaseQty">+</view>
        </view>
      </view>
    </view>

    <view class="detail-section card">
      <view class="detail-title">商品详情</view>
      <view class="detail-content">
        <view class="detail-item">
          <text class="detail-label">商品名称</text>
          <text class="detail-text">{{product.name}}</text>
        </view>
        <view class="detail-item">
          <text class="detail-label">商品规格</text>
          <text class="detail-text">{{product.unit}}</text>
        </view>
        <view class="detail-item">
          <text class="detail-label">储存方式</text>
          <text class="detail-text">冷藏保存，请尽快食用</text>
        </view>
        <view class="detail-item">
          <text class="detail-label">保质期</text>
          <text class="detail-text">7天（冷藏）</text>
        </view>
        <view class="detail-desc">
          <text class="detail-label">商品描述</text>
          <view class="desc-text">{{product.description}}</view>
        </view>
      </view>
    </view>

    <view class="bottom-space"></view>
  </scroll-view>

  <view class="bottom-bar">
    <view class="bar-left">
      <view class="bar-item" bindtap="goHome">
        <text class="bar-icon">🏠</text>
        <text class="bar-text">首页</text>
      </view>
      <view class="bar-item" bindtap="goCart">
        <text class="bar-icon">🛒</text>
        <text class="bar-text">购物车</text>
        <view class="cart-badge" wx:if="{{cartCount > 0}}">{{cartCount > 99 ? '99+' : cartCount}}</view>
      </view>
    </view>
    <view class="bar-right">
      <button class="btn-add-cart" bindtap="showSpecPopup">加入购物车</button>
      <button class="btn-buy-now" bindtap="buyNow">立即购买</button>
    </view>
  </view>

  <view class="spec-popup {{showSpec ? 'show' : ''}}" catchtap="hideSpecPopup" wx:if="{{product.specs}}">
    <view class="spec-content" catchtap="stopPropagation">
      <view class="spec-header">
        <image src="{{product.image}}" class="spec-product-image"></image>
        <view class="spec-product-info">
          <view class="spec-product-price">
            <text class="symbol">¥</text>
            <text class="price">{{selectedSpec ? selectedSpec.price : currentPrice}}</text>
          </view>
          <view class="spec-product-stock">库存 {{selectedSpec ? selectedSpec.stock : product.stock}} 件</view>
          <view class="spec-product-selected">已选：{{selectedSpec ? selectedSpec.name : '请选择规格'}}</view>
        </view>
        <view class="spec-close" bindtap="hideSpecPopup">✕</view>
      </view>
      
      <view class="spec-body">
        <view class="spec-group">
          <view class="spec-group-title">规格</view>
          <view class="spec-options">
            <view 
              class="spec-option {{selectedSpec && selectedSpec.id === item.id ? 'active' : ''}}"
              wx:for="{{product.specs}}" 
              wx:key="id"
              bindtap="selectSpec"
              data-spec="{{item}}"
            >
              {{item.name}}
            </view>
          </view>
        </view>
        
        <view class="spec-group">
          <view class="spec-group-title">数量</view>
          <view class="spec-quantity">
            <view class="qty-btn minus" bindtap="decreaseQty">-</view>
            <text class="qty-value">{{quantity}}</text>
            <view class="qty-btn plus" bindtap="increaseQty">+</view>
          </view>
        </view>
      </view>
      
      <view class="spec-footer">
        <button class="btn-confirm" bindtap="confirmAddCart">加入购物车</button>
      </view>
    </view>
  </view>
</view>
