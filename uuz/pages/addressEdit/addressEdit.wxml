<view class="page">
  <view class="form-section">
    <view class="form-item">
      <view class="form-label">收货人</view>
      <input 
        class="form-input" 
        placeholder="请输入收货人姓名" 
        placeholder-class="form-placeholder"
        value="{{form.name}}"
        bindinput="onInput"
        data-field="name"
      />
    </view>
    <view class="form-divider"></view>
    
    <view class="form-item">
      <view class="form-label">手机号</view>
      <input 
        class="form-input" 
        type="number"
        placeholder="请输入手机号码" 
        placeholder-class="form-placeholder"
        value="{{form.phone}}"
        bindinput="onInput"
        data-field="phone"
        maxlength="11"
      />
    </view>
    <view class="form-divider"></view>
    
    <picker mode="region" bindchange="onRegionChange" value="{{[form.province, form.city, form.district]}}">
      <view class="form-item">
        <view class="form-label">所在地区</view>
        <view class="form-value {{regionText ? '' : 'placeholder'}}">
          {{regionText || '请选择省/市/区'}}
        </view>
        <text class="form-arrow">›</text>
      </view>
    </picker>
    <view class="form-divider"></view>
    
    <view class="form-item form-item-textarea">
      <view class="form-label">详细地址</view>
      <textarea 
        class="form-textarea" 
        placeholder="请输入详细地址，如街道、门牌号等" 
        placeholder-class="form-placeholder"
        value="{{form.detail}}"
        bindinput="onInput"
        data-field="detail"
        maxlength="200"
      />
    </view>
  </view>

  <view class="default-section">
    <view class="default-label">设为默认地址</view>
    <switch 
      checked="{{form.isDefault}}" 
      color="#ff6b35"
      bindchange="onDefaultChange"
    />
  </view>

  <view class="bottom-bar">
    <button class="btn-save" bindtap="saveAddress">保存地址</button>
  </view>
</view>
