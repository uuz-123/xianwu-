.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

.form-section {
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 0 30rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  position: relative;
}

.form-item-textarea {
  align-items: flex-start;
  padding: 28rpx 0;
}

.form-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  height: 100%;
}

.form-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.form-value.placeholder {
  color: #999;
}

.form-textarea {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  min-height: 120rpx;
  line-height: 1.5;
}

.form-placeholder {
  color: #999;
  font-size: 28rpx;
}

.form-arrow {
  font-size: 32rpx;
  color: #ccc;
  margin-left: 10rpx;
}

.form-divider {
  height: 1rpx;
  background: #f0f0f0;
  margin-left: 160rpx;
}

.default-section {
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 28rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.default-label {
  font-size: 28rpx;
  color: #333;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.08);
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.btn-save {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #ff6b35 0%, #ff4e50 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  border: none;
}

.btn-save::after {
  border: none;
}
