.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #fff;
}

.search-header {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.search-bar {
  flex: 1;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
}

.search-icon {
  font-size: 28rpx;
  color: #999;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  height: 100%;
}

.search-placeholder {
  color: #999;
  font-size: 28rpx;
}

.clear-btn {
  width: 40rpx;
  height: 40rpx;
  background: #ddd;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
}

.cancel-btn {
  font-size: 28rpx;
  color: #666;
  margin-left: 24rpx;
}

.search-content {
  flex: 1;
  padding: 30rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.clear-history {
  font-size: 24rpx;
  color: #999;
}

.history-section {
  margin-bottom: 40rpx;
}

.history-tags {
  display: flex;
  flex-wrap: wrap;
}

.history-tag {
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  margin-right: 20rpx;
  margin-bottom: 20rpx;
}

.hot-tags {
  display: flex;
  flex-direction: column;
}

.hot-tag {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.hot-index {
  width: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: #ff6b35;
  margin-right: 20rpx;
}

.hot-tag:nth-child(n+4) .hot-index {
  color: #999;
}

.hot-text {
  font-size: 28rpx;
  color: #333;
}

.search-result {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.result-header {
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #f0f0f0;
  background: #fff;
}

.result-count {
  font-size: 24rpx;
  color: #999;
}

.sort-tabs {
  display: flex;
  align-items: center;
}

.sort-tab {
  font-size: 26rpx;
  color: #666;
  margin-left: 30rpx;
  display: flex;
  align-items: center;
}

.sort-tab.active {
  color: #ff6b35;
  font-weight: bold;
}

.sort-arrow {
  font-size: 22rpx;
  margin-left: 4rpx;
}

.result-list {
  flex: 1;
  padding: 0 20rpx;
}

.product-item {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  position: relative;
}

.product-item:last-child {
  border-bottom: none;
}

.product-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #f5f5f5;
}

.product-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding-right: 60rpx;
}

.product-name {
  font-size: 28rpx;
  color: #333;
  line-height: 1.4;
}

.product-tags {
  display: flex;
  flex-wrap: wrap;
  margin: 8rpx 0;
}

.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  font-size: 20rpx;
  border-radius: 8rpx;
  margin-right: 8rpx;
}

.tag-hot {
  background: #ffebe0;
  color: #ff6b35;
}

.tag-new {
  background: #e0f7ff;
  color: #00a8ff;
}

.product-bottom {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.product-price {
  display: flex;
  align-items: baseline;
}

.product-price .price-symbol {
  font-size: 22rpx;
  color: #ff6b35;
}

.product-price .price-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6b35;
}

.original-price {
  font-size: 22rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 10rpx;
}

.product-sales {
  font-size: 22rpx;
  color: #999;
}

.add-cart-btn {
  position: absolute;
  right: 0;
  bottom: 24rpx;
  width: 52rpx;
  height: 52rpx;
  background: linear-gradient(135deg, #ff6b35 0%, #ff8c5a 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 36rpx;
  line-height: 1;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: #999;
}

.bottom-tip {
  text-align: center;
  padding: 40rpx 0;
  color: #ccc;
  font-size: 24rpx;
}
