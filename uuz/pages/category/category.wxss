.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.search-bar {
  padding: 20rpx 30rpx;
  background: #fff;
}

.search-input {
  height: 64rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
}

.search-input .iconfont {
  font-size: 26rpx;
  color: #999;
  margin-right: 12rpx;
}

.search-placeholder {
  color: #999;
  font-size: 26rpx;
}

.category-container {
  flex: 1;
  display: flex;
  overflow: hidden;
}

.category-left {
  width: 180rpx;
  height: 100%;
  background: #f5f5f5;
}

.category-item {
  padding: 30rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  transition: all 0.3s;
}

.category-item.active {
  background: #fff;
}

.category-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 48rpx;
  background: #ff6b35;
  border-radius: 0 3rpx 3rpx 0;
}

.item-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.item-name {
  font-size: 24rpx;
  color: #333;
  text-align: center;
}

.category-item.active .item-name {
  color: #ff6b35;
  font-weight: bold;
}

.category-right {
  flex: 1;
  height: 100%;
  background: #fff;
  padding: 0 20rpx;
}

.right-header {
  position: relative;
  margin: 20rpx 0;
  border-radius: 12rpx;
  overflow: hidden;
}

.header-image {
  width: 100%;
  height: 160rpx;
}

.header-title {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding-left: 30rpx;
  background: linear-gradient(90deg, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0) 100%);
}

.title-main {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.title-sub {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
}

.product-list {
  padding-bottom: 40rpx;
}

.product-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  position: relative;
}

.product-item:last-child {
  border-bottom: none;
}

.product-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.product-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding-right: 60rpx;
}

.product-name {
  font-size: 26rpx;
  color: #333;
  line-height: 1.4;
}

.product-tags {
  display: flex;
  flex-wrap: wrap;
  margin: 8rpx 0;
}

.product-bottom {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.product-price {
  display: flex;
  align-items: baseline;
}

.product-price .price-symbol {
  font-size: 22rpx;
  color: #ff6b35;
}

.product-price .price-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6b35;
}

.original-price {
  font-size: 22rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 10rpx;
}

.product-sales {
  font-size: 20rpx;
  color: #999;
}

.add-cart-btn {
  position: absolute;
  right: 0;
  bottom: 20rpx;
  width: 52rpx;
  height: 52rpx;
  background: linear-gradient(135deg, #ff6b35 0%, #ff8c5a 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 36rpx;
  line-height: 1;
}

.empty {
  padding: 100rpx 0;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

.bottom-tip {
  text-align: center;
  padding: 30rpx 0;
  color: #ccc;
  font-size: 24rpx;
}
