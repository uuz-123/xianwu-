<view class="page">
  <view class="header">
    <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>
    <view class="search-bar">
      <view class="search-input" bindtap="goSearch">
        <text class="iconfont">🔍</text>
        <text class="search-placeholder">搜索新鲜好物</text>
      </view>
    </view>
  </view>

  <scroll-view scroll-y="true" class="content" bindscrolltolower="loadMore">
    <swiper class="banner" indicator-dots="true" autoplay="true" interval="3000" duration="500" circular="true" indicator-color="rgba(255,255,255,0.5)" indicator-active-color="#fff">
      <swiper-item wx:for="{{banners}}" wx:key="id" bindtap="goBanner" data-item="{{item}}">
        <image src="{{item.image}}" class="banner-image" mode="aspectFill"></image>
      </swiper-item>
    </swiper>

    <view class="category-nav card">
      <view class="category-item" wx:for="{{categories}}" wx:key="id" bindtap="goCategory" data-id="{{item.id}}">
        <view class="category-icon">{{item.icon}}</view>
        <text class="category-name">{{item.name}}</text>
      </view>
    </view>

    <view class="seckill-section card">
      <view class="section-header">
        <view class="seckill-title">
          <text class="seckill-icon">⚡</text>
          <text class="seckill-name">限时秒杀</text>
        </view>
        <view class="seckill-countdown">
          <text class="countdown-text">距结束</text>
          <text class="countdown-time">{{countdown}}</text>
        </view>
        <view class="more-link" bindtap="goSeckillMore">
          更多
          <text class="arrow">›</text>
        </view>
      </view>
      <scroll-view scroll-x="true" class="seckill-list" enhanced="true" show-scrollbar="false">
        <view class="seckill-item" wx:for="{{seckillProducts}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
          <image src="{{item.image}}" class="seckill-image" mode="aspectFill"></image>
          <view class="seckill-tag">{{item.tag}}</view>
          <view class="seckill-info">
            <view class="seckill-price">
              <text class="price-symbol">¥</text>
              <text class="price-value">{{item.price}}</text>
            </view>
            <view class="seckill-original">¥{{item.originalPrice}}</view>
          </view>
          <view class="seckill-progress">
            <view class="progress-bar">
              <view class="progress-inner" style="width: {{item.sold / (item.sold + item.stock) * 100}}%"></view>
            </view>
            <text class="progress-text">已抢{{item.sold}}件</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <view class="section new-section">
      <view class="section-title">
        <text>新品推荐</text>
        <view class="section-subtitle">新鲜直达 品质优选</view>
      </view>
      <view class="product-grid">
        <view class="product-card" wx:for="{{newProducts}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
          <image src="{{item.image}}" class="product-image" mode="aspectFill"></image>
          <view class="product-badges">
            <text class="badge-new" wx:if="{{item.isNew}}">新品</text>
          </view>
          <view class="product-info">
            <view class="product-name text-ellipsis-2">{{item.name}}</view>
            <view class="product-bottom">
              <view class="product-price">
                <text class="price-symbol">¥</text>
                <text class="price-value">{{item.price}}</text>
              </view>
              <view class="product-sales">{{item.sales}}人付款</view>
            </view>
            <view class="add-cart-btn" catchtap="addCart" data-id="{{item.id}}">
              <text>+</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="section hot-section">
      <view class="section-title">
        <text>热销爆款</text>
        <view class="section-subtitle">人气之选 不容错过</view>
      </view>
      <view class="product-grid">
        <view class="product-card" wx:for="{{hotProducts}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
          <image src="{{item.image}}" class="product-image" mode="aspectFill"></image>
          <view class="product-badges">
            <text class="badge-hot" wx:if="{{item.isHot}}">热卖</text>
          </view>
          <view class="product-info">
            <view class="product-name text-ellipsis-2">{{item.name}}</view>
            <view class="product-bottom">
              <view class="product-price">
                <text class="price-symbol">¥</text>
                <text class="price-value">{{item.price}}</text>
              </view>
              <view class="product-sales">{{item.sales}}人付款</view>
            </view>
            <view class="add-cart-btn" catchtap="addCart" data-id="{{item.id}}">
              <text>+</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="bottom-tip" wx:if="{{refreshTime > 0}}">
      <text>— 发现更多新鲜好物 —</text>
    </view>
  </scroll-view>
</view>
