.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.header {
  background: linear-gradient(135deg, #ff6b35 0%, #ff8c5a 100%);
  position: relative;
  z-index: 100;
}

.status-bar {
  width: 100%;
}

.search-bar {
  padding: 20rpx 30rpx 30rpx;
}

.search-input {
  height: 72rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
}

.search-input .iconfont {
  font-size: 28rpx;
  color: #999;
  margin-right: 16rpx;
}

.search-placeholder {
  color: #999;
  font-size: 26rpx;
}

.content {
  flex: 1;
  overflow: hidden;
}

.banner {
  width: 100%;
  height: 320rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.category-nav {
  margin: 20rpx;
  padding: 30rpx 20rpx;
  display: flex;
  flex-wrap: wrap;
}

.category-item {
  width: 20%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20rpx;
}

.category-icon {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #fff5f0 0%, #ffe8dc 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-bottom: 12rpx;
}

.category-name {
  font-size: 24rpx;
  color: #333;
}

.seckill-section {
  margin: 0 20rpx 20rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, #fff5f0 0%, #ffe8dc 100%);
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.seckill-title {
  display: flex;
  align-items: center;
}

.seckill-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.seckill-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff6b35;
}

.seckill-countdown {
  display: flex;
  align-items: center;
  margin-left: 20rpx;
}

.countdown-text {
  font-size: 22rpx;
  color: #666;
  margin-right: 8rpx;
}

.countdown-time {
  font-size: 24rpx;
  color: #fff;
  background: #ff6b35;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  font-weight: bold;
}

.more-link {
  margin-left: auto;
  font-size: 24rpx;
  color: #999;
  display: flex;
  align-items: center;
}

.more-link .arrow {
  font-size: 28rpx;
  margin-left: 4rpx;
}

.seckill-list {
  white-space: nowrap;
  padding-bottom: 10rpx;
}

.seckill-item {
  display: inline-block;
  width: 200rpx;
  margin-right: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  padding-bottom: 16rpx;
  position: relative;
  vertical-align: top;
}

.seckill-item:last-child {
  margin-right: 0;
}

.seckill-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx 12rpx 0 0;
}

.seckill-tag {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  background: #ff6b35;
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
}

.seckill-info {
  padding: 12rpx 12rpx 0;
}

.seckill-price {
  color: #ff6b35;
  font-weight: bold;
}

.seckill-price .price-symbol {
  font-size: 22rpx;
}

.seckill-price .price-value {
  font-size: 32rpx;
}

.seckill-original {
  font-size: 20rpx;
  color: #999;
  text-decoration: line-through;
  margin-top: 4rpx;
}

.seckill-progress {
  padding: 8rpx 12rpx 0;
}

.progress-bar {
  height: 12rpx;
  background: #ffe8dc;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-inner {
  height: 100%;
  background: linear-gradient(90deg, #ff6b35, #ff8c5a);
  border-radius: 6rpx;
}

.progress-text {
  font-size: 18rpx;
  color: #ff6b35;
  margin-top: 4rpx;
  display: block;
}

.section {
  padding: 0 20rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  padding: 20rpx 0;
  display: flex;
  align-items: baseline;
}

.section-subtitle {
  font-size: 24rpx;
  color: #999;
  font-weight: normal;
  margin-left: 16rpx;
}

.product-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.product-card {
  width: 345rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  position: relative;
}

.product-image {
  width: 345rpx;
  height: 345rpx;
}

.product-badges {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  display: flex;
}

.badge-new {
  background: #00a8ff;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 8rpx;
}

.badge-hot {
  background: #ff6b35;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 8rpx;
}

.product-info {
  padding: 16rpx;
  position: relative;
}

.product-name {
  font-size: 26rpx;
  color: #333;
  line-height: 1.4;
  height: 72rpx;
  margin-bottom: 12rpx;
}

.product-bottom {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.product-price {
  color: #ff6b35;
  font-weight: bold;
}

.product-price .price-symbol {
  font-size: 22rpx;
}

.product-price .price-value {
  font-size: 36rpx;
}

.product-sales {
  font-size: 20rpx;
  color: #999;
}

.add-cart-btn {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #ff6b35 0%, #ff8c5a 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 36rpx;
  line-height: 1;
}

.bottom-tip {
  text-align: center;
  padding: 40rpx 0;
  color: #ccc;
  font-size: 24rpx;
}
