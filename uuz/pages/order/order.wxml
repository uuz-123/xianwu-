<view class="page">
  <view class="tabs">
    <view 
      class="tab-item {{currentTab === item.status ? 'active' : ''}}" 
      wx:for="{{tabs}}" 
      wx:key="status"
      bindtap="switchTab"
      data-status="{{item.status}}"
    >
      {{item.name}}
    </view>
  </view>

  <scroll-view scroll-y="true" class="order-list" enhanced="true" show-scrollbar="false">
    <view class="order-card" wx:for="{{filteredOrders}}" wx:key="id">
      <view class="order-header">
        <text class="order-no">订单号：{{item.orderNo}}</text>
        <text class="order-status status-{{item.status}}">{{item.statusText}}</text>
      </view>
      
      <view class="order-items" bindtap="goOrderDetail" data-id="{{item.id}}">
        <view class="order-item" wx:for="{{item.items}}" wx:for-item="goods" wx:key="specKey">
          <image src="{{goods.image}}" class="goods-image" mode="aspectFill"></image>
          <view class="goods-info">
            <view class="goods-name text-ellipsis-2">{{goods.name}}</view>
            <view class="goods-spec" wx:if="{{goods.spec}}">{{goods.spec.name}}</view>
            <view class="goods-bottom">
              <view class="goods-price">
                <text class="price-symbol">¥</text>
                <text class="price-value">{{goods.price}}</text>
              </view>
              <view class="goods-qty">x{{goods.quantity}}</view>
            </view>
          </view>
        </view>
      </view>
      
      <view class="order-footer">
        <view class="order-total">
          <text class="total-label">共{{item.totalCount}}件商品 实付：</text>
          <text class="total-price">
            <text class="price-symbol">¥</text>
            <text class="price-value">{{item.totalPrice}}</text>
          </text>
        </view>
        <view class="order-actions">
          <button class="btn-outline" wx:if="{{item.status === 0}}" bindtap="cancelOrder" data-id="{{item.id}}">取消订单</button>
          <button class="btn-primary" wx:if="{{item.status === 0}}" bindtap="payOrder" data-id="{{item.id}}">去付款</button>
          <button class="btn-outline" wx:if="{{item.status === 1}}" bindtap="remindShip" data-id="{{item.id}}">提醒发货</button>
          <button class="btn-primary" wx:if="{{item.status === 2}}" bindtap="confirmReceive" data-id="{{item.id}}">确认收货</button>
          <button class="btn-outline" wx:if="{{item.status === 3}}" bindtap="buyAgain" data-id="{{item.id}}">再次购买</button>
          <button class="btn-outline" wx:if="{{item.status === 3}}" bindtap="goAfterSale" data-id="{{item.id}}">申请售后</button>
        </view>
      </view>
    </view>

    <view class="empty" wx:if="{{filteredOrders.length === 0}}">
      <text class="empty-icon">📦</text>
      <text class="empty-text">暂无相关订单</text>
      <button class="btn-go-shopping" bindtap="goShopping">去逛逛</button>
    </view>

    <view class="bottom-tip" wx:if="{{filteredOrders.length > 0}}">
      <text>— 没有更多订单了 —</text>
    </view>
  </scroll-view>
</view>
